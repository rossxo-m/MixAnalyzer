# Anthropic API key — required for Tier 3 /feedback endpoint.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model override. Defaults to claude-sonnet-4-6.
# Pricing per 1M tokens: haiku-4-5 $1/$5 · sonnet-4-6 $3/$15 · opus-4-6 $5/$25.
# MIX_ANALYZER_MODEL=claude-haiku-4-5

# Optional: additional origins allowed by CORS (comma-separated).
# Built-in allow list already includes common Vite dev ports.
# EXTRA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5173
